# dependencies
/node_modules
/.pnp
.pnp.*

# next.js
/.next/
/out/

# production
/build

# environment variables (secrets — never commit)
.env
.env*.local

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# typescript / next
next-env.d.ts
*.tsbuildinfo

