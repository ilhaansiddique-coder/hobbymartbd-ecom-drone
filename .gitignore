.DS_Store
*.pem

# local postgres cluster data (lives in $HOME, but ignore if ever placed here)
/.hobbymart-pgdata/

# generated prisma client (regenerated by 'prisma generate' postinstall)
/src/generated/

# locally uploaded images (served at /uploads)
/public/uploads/
