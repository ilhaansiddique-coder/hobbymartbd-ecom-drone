{
  "name": "hobbymart",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "seed": "tsx prisma/seed.ts",
    "db:start": "/usr/lib/postgresql/18/bin/pg_ctl -D $HOME/.hobbymart-pgdata -l $HOME/.hobbymart-pgdata/server.log -w start",
    "db:stop": "/usr/lib/postgresql/18/bin/pg_ctl -D $HOME/.hobbymart-pgdata -w stop",
    "db:status": "/usr/lib/postgresql/18/bin/pg_ctl -D $HOME/.hobbymart-pgdata status",
    "postinstall": "prisma generate",
    "lint": "eslint"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@uploadthing/react": "^6.6.0",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.16.0",
    "next": "^16.2.9",
    "next-auth": "^4.24.14",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.0",
    "recharts": "^2.15.4",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uploadthing": "^6.12.0",
    "zod": "^4.4.3",
    "zxing-wasm": "^3.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.0",
    "typescript": "^5"
  }
