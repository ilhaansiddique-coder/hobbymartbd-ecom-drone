# Copy to .env and fill in real values. Do NOT commit .env.
# Local Postgres (self-owned cluster on port 5433 — see package.json db:* scripts)
DATABASE_URL="postgresql://hobbymart:hobbymart@127.0.0.1:5433/hobbymart"

# NextAuth (v4)
NEXTAUTH_URL="http://localhost:3000"
# Generate a fresh secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-your-own-secret"
